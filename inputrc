# http://stackoverflow.com/a/17144421/199644
# set show-mode-in-prompt on

# https://unix.stackexchange.com/a/104101/17796
# Use ctrl+L to clear screen in insert mode
set editing-mode vi
$if mode=vi

set keymap vi-command
# these are for vi-command mode
Control-l: clear-screen

set keymap vi-insert
# these are for vi-insert mode
Control-l: clear-screen
$endif
